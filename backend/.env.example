# =======================================================
# CYBER FORGE AI - BACKEND ENVIRONMENT CONFIGURATION
# =======================================================
# Copy this file to .env and fill in your actual values
# Never commit the .env file to version control!

# =======================================================
# SERVER CONFIGURATION
# =======================================================
# Port for the backend server to run on
PORT=8000

# Environment (development, staging, production)
NODE_ENV=development

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006,http://localhost:8080

# =======================================================
# DATABASE CONFIGURATION
# =======================================================
# MongoDB Connection String
# For local MongoDB: mongodb://localhost:27017/cyberforge
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/cyberforge
DATABASE_URL=mongodb://localhost:27017/cyberforge

# PostgreSQL Connection String (for analytics/reporting)
# Format: postgresql://username:password@localhost:5432/cyberforge
POSTGRES_URL=postgresql://user:password@localhost:5432/cyberforge

# Redis Connection String (for caching and sessions)
# Format: redis://[username:password@]host:port
REDIS_URL=redis://localhost:6379

# Database connection pool settings
DB_MAX_CONNECTIONS=10
DB_CONNECTION_TIMEOUT=30000

# =======================================================
# SECURITY & AUTHENTICATION
# =======================================================
# JWT Secret Key (generate a strong random key)
# Use: openssl rand -base64 64
JWT_SECRET=your-super-secure-jwt-secret-key-here-make-it-long-and-random

# JWT Token Expiration
JWT_EXPIRES_IN=24h

# Bcrypt Salt Rounds (higher = more secure but slower)
BCRYPT_SALT_ROUNDS=12

# =======================================================
# APPWRITE CONTROL PLANE (MANDATORY FOR TODO 1)
# =======================================================
# Appwrite is the single source of truth for identity, authentication, 
# permissions, and agent control. NO service may re-implement auth.

# Appwrite Endpoint (Cloud or Self-hosted)
# For Appwrite Cloud: https://cloud.appwrite.io/v1
# For Self-hosted: http://localhost/v1
APPWRITE_ENDPOINT=https://nyc.cloud.appwrite.io/v1

# Appwrite Project ID (Get from Appwrite Console)
APPWRITE_PROJECT_ID=698d422300098f2baa8a

# Appwrite API Key (Server-side API key with full permissions)
APPWRITE_API_KEY=your-appwrite-api-key

# Appwrite Database ID
APPWRITE_DATABASE_ID=cyberforge

# Appwrite Collection IDs
APPWRITE_COLLECTION_USERS=users
APPWRITE_COLLECTION_DEVICES=devices
APPWRITE_COLLECTION_BROWSERS=browsers
APPWRITE_COLLECTION_BROWSER_EVENTS=browser_events
APPWRITE_COLLECTION_AGENTS=agents
APPWRITE_COLLECTION_AGENT_TASKS=agent_tasks
APPWRITE_COLLECTION_ALERTS=alerts
APPWRITE_COLLECTION_BROWSER_INTELLIGENCE=browser_intelligence
APPWRITE_COLLECTION_EVIDENCE_METADATA=evidence_metadata

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Session Configuration
SESSION_SECRET=your-session-secret-key-here
SESSION_MAX_AGE=86400000

# =======================================================
# AI & MACHINE LEARNING SERVICES
# =======================================================
# ML Services URL
AI_SERVICE_URL=http://localhost:8001

# Google Gemini API Configuration (Required for AI functionality)
GEMINI_API_KEY=AIzaSyCcZ_PgY1N3u1WD1Llw500rapaY8T9Zp2I

# Gemini Model Configuration
GEMINI_MODEL=gemini-pro
GEMINI_TEMPERATURE=0.3
GEMINI_MAX_TOKENS=2048

# Custom Training Data Paths
TRAINING_DATA_PATH=./training_data
CUSTOM_KNOWLEDGE_BASE=./knowledge_base

# Deprecated: Hugging Face Configuration (kept for backward compatibility)
HUGGINGFACE_API_TOKEN=your-huggingface-token-here-optional

# ChromaDB Configuration (Free vector database)
CHROMADB_HOST=localhost
CHROMADB_PORT=8000
CHROMADB_COLLECTION_NAME=cyber_forge_vectors

# =======================================================
# EXTERNAL SERVICES & APIs
# =======================================================
# Web Scraping Configuration
SCRAPING_TIMEOUT=30000
SCRAPING_MAX_RETRIES=3
SCRAPING_USER_AGENT=CyberForgeAI/1.0

# Threat Intelligence APIs
VIRUSTOTAL_API_KEY=your-virustotal-api-key-here
SHODAN_API_KEY=your-shodan-api-key-here
ALIENVAULT_API_KEY=your-alienvault-api-key-here

# Email Service (for notifications)
EMAIL_SERVICE=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# SMS/Push Notifications
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# =======================================================
# WEBSOCKET CONFIGURATION
# =======================================================
# WebSocket Server Configuration
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_CONNECTIONS=1000
WS_CONNECTION_TIMEOUT=60000

# Real-time Communication
DESKTOP_WS_PORT=8001
MOBILE_WS_PORT=8002

# =======================================================
# LOGGING & MONITORING
# =======================================================
# Log Level (error, warn, info, verbose, debug, silly)
LOG_LEVEL=info

# Log File Configuration
LOG_FILE_PATH=./logs/application.log
LOG_FILE_MAX_SIZE=10M
LOG_FILE_MAX_FILES=5

# Error Tracking (Sentry)
SENTRY_DSN=your-sentry-dsn-here
SENTRY_ENVIRONMENT=development

# Application Performance Monitoring
APM_SERVICE_NAME=cyber-forge-backend
APM_SERVICE_VERSION=1.0.0

# =======================================================
# DATADOG OBSERVABILITY (MANDATORY FOR TODO 1)
# =======================================================
# Datadog is used for system health, NOT business logic.
# Tracks: agent heartbeat, scan duration, API calls, ML inference, 
# Gemini usage, errors, and retries.

# Enable Datadog integration
DATADOG_ENABLED=true

# Datadog API Key (Get from Datadog console)
DATADOG_API_KEY=your-datadog-api-key

# Datadog Service Name
DATADOG_SERVICE_NAME=cyberforge-backend

# Datadog Agent Configuration (for StatsD metrics)
DATADOG_AGENT_HOST=localhost
DATADOG_AGENT_PORT=8126

# Datadog Log Level
DATADOG_LOG_LEVEL=info

# Enable profiling
DATADOG_PROFILING=false

# Enable runtime metrics
DATADOG_RUNTIME_METRICS=true

# =======================================================
# FILE STORAGE & UPLOADS
# =======================================================
# File Upload Configuration
UPLOAD_MAX_SIZE=50MB
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,pdf,txt,csv,json
UPLOAD_DESTINATION=./uploads

# Cloud Storage (AWS S3, Google Cloud, Azure)
CLOUD_STORAGE_PROVIDER=aws
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=cyber-forge-uploads

# =======================================================
# CYBERSECURITY FEATURES
# =======================================================
# Malware Scanning
MALWARE_SCAN_ENABLED=true
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# Network Security
NETWORK_MONITORING_ENABLED=true
INTRUSION_DETECTION_THRESHOLD=0.8

# Threat Detection
THREAT_DETECTION_ENABLED=true
THREAT_SCORE_THRESHOLD=7.0
AUTO_BLOCK_MALICIOUS_IPS=false

# =======================================================
# PERFORMANCE & CACHING
# =======================================================
# Cache Configuration
CACHE_TTL=3600
CACHE_MAX_KEYS=10000

# Database Query Optimization
DB_QUERY_TIMEOUT=30000
DB_ENABLE_QUERY_LOGGING=false

# Background Jobs
JOB_QUEUE_ENABLED=true
JOB_QUEUE_REDIS_URL=redis://localhost:6379
JOB_CONCURRENCY=5

# =======================================================
# DEVELOPMENT & DEBUGGING
# =======================================================
# Development Mode Features
DEBUG_MODE=false
VERBOSE_LOGGING=false
ENABLE_PLAYGROUND=false

# Testing Configuration
TEST_DATABASE_URL=mongodb://localhost:27017/cyberforge_test
TEST_REDIS_URL=redis://localhost:6379/1

# Mock External Services (for development)
MOCK_EXTERNAL_APIS=false
MOCK_AI_RESPONSES=false

# =======================================================
# MOBILE & DESKTOP APP INTEGRATION
# =======================================================
# Mobile App Configuration
MOBILE_APP_VERSION=1.0.0
MOBILE_FORCE_UPDATE=false
MOBILE_MIN_VERSION=1.0.0

# Desktop App Configuration
DESKTOP_APP_VERSION=1.0.0
DESKTOP_AUTO_UPDATE=true
DESKTOP_UPDATE_CHECK_INTERVAL=3600000

# Cross-platform features
SYNC_USER_PREFERENCES=true
REAL_TIME_NOTIFICATIONS=true

# =======================================================
# BACKUP & DISASTER RECOVERY
# =======================================================
# Database Backup
AUTO_BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# Data Export
EXPORT_ENCRYPTION_KEY=your-export-encryption-key
EXPORT_MAX_RECORDS=100000

# =======================================================
# COMPLIANCE & PRIVACY
# =======================================================
# Data Privacy
GDPR_COMPLIANCE=true
DATA_RETENTION_DAYS=365
ANONYMIZE_LOGS=true

# Audit Logging
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=90

# Security Headers
ENABLE_HSTS=true
ENABLE_CSP=true
ENABLE_REFERRER_POLICY=true

GOOGLE_CLIENT_ID=90481270348-i3mniqc5a9o5ffe6iin088rcmvpqrkak.apps.googleusercontent.com