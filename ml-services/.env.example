# =======================================================
# CYBER FORGE AI - ML SERVICES ENVIRONMENT CONFIGURATION
# =======================================================
# Copy this file to .env and fill in your actual values
# Never commit the .env file to version control!

# =======================================================
# SERVER CONFIGURATION
# =======================================================
# Port for the ML service to run on
PORT=8001

# Environment (development, staging, production)
ENVIRONMENT=development

# Host to bind to (0.0.0.0 for all interfaces)
HOST=0.0.0.0

# Number of workers (for production)
WORKERS=4

# CORS allowed origins (comma-separated)
ALLOWED_HOSTS=http://localhost:8000,http://localhost:3000,http://localhost:8080

# =======================================================
# AI SERVICE CONFIGURATION
# =======================================================
# Google Gemini API Key (Required for AI features)
# Get your key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini Model Configuration
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MAX_TOKENS=8192
GEMINI_TEMPERATURE=0.7

# OpenAI API Key (Optional, for fallback)
# OPENAI_API_KEY=your-openai-api-key

# =======================================================
# MODEL CONFIGURATION
# =======================================================
# Directory for storing trained models
MODELS_DIR=./models

# Directory for datasets
DATASETS_DIR=./datasets

# Maximum model file size (in MB)
MAX_MODEL_SIZE=500

# Training timeout (in seconds)
TRAINING_TIMEOUT=3600

# =======================================================
# DATABASE CONFIGURATION
# =======================================================
# MongoDB for storing model metadata
MONGODB_URI=mongodb://localhost:27017/cyberforge_ml

# Redis for caching (optional)
# REDIS_URL=redis://localhost:6379

# =======================================================
# KAGGLE CONFIGURATION (for dataset downloads)
# =======================================================
# Kaggle credentials (for automatic dataset downloads)
# Download kaggle.json from https://www.kaggle.com/account
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-api-key

# =======================================================
# THREAT INTELLIGENCE
# =======================================================
# VirusTotal API Key
VIRUSTOTAL_API_KEY=your-virustotal-api-key

# AbuseIPDB API Key
ABUSEIPDB_API_KEY=your-abuseipdb-api-key

# Shodan API Key
SHODAN_API_KEY=your-shodan-api-key

# URLScan.io API Key
URLSCAN_API_KEY=your-urlscan-api-key

# =======================================================
# MEMORY & PERFORMANCE
# =======================================================
# Maximum memory for model loading (in MB)
MAX_MEMORY_MB=4096

# Batch size for predictions
DEFAULT_BATCH_SIZE=32

# Number of threads for CPU operations
NUM_THREADS=4

# GPU Configuration (set to -1 to disable)
GPU_DEVICE=-1

# =======================================================
# LOGGING
# =======================================================
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path
LOG_FILE=./logs/ml-service.log

# =======================================================
# SECURITY
# =======================================================
# API Key for service authentication
API_KEY=your-ml-service-api-key

# Rate limiting (requests per minute)
RATE_LIMIT=60

# =======================================================
# EXTERNAL SERVICES
# =======================================================
# Backend service URL
BACKEND_URL=http://localhost:8000

# Web scraping proxy (optional)
# PROXY_URL=http://proxy:port
