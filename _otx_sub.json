:21","content":"","title":"Macho","description":"MD5 of 522fdfaff44797b9180f36c654f77baf5cdeaab861bbf372ccfc1a5bd920d62e","expiration":null,"is_active":1,"role":null},{"id":4348854188,"indicator":"5144bf4e32c5832c426ad3da55d45f026f66bc95","type":"FileHash-SHA1","created":"2026-05-08T08:50:21","content":"","title":"Macho","description":"SHA1 of 522fdfaff44797b9180f36c654f77baf5cdeaab861bbf372ccfc1a5bd920d62e","expiration":null,"is_active":1,"role":null},{"id":4348854189,"indicator":"a2421f7fd4be6b12382150033507af7aa8bf6241","type":"FileHash-SHA1","created":"2026-05-08T08:50:21","content":"","title":"Macho","description":"SHA1 of 9d2da07aa6e7db3fbc36b36f0cfd74f78d5815f5ba55d0f0405cdd668bd13767","expiration":null,"is_active":1,"role":null}],"tags":["phantompulse","infostealer","shub stealer","clickfix","applescript","macos"],"targeted_countries":[],"malware_families":["Macsync","Shub Stealer","AMOS","PhantomPulse"],"attack_ids":["T1059.007","T1539","T1555.001","T1082","T1059.002","T1005","T1140","T1036","T1560","T1543.004","T1555.003","T1087","T1083","T1552.001","T1204","T1041","T1574","T1027","T1614","T1543.001"],"references":["https:\/\/www.microsoft.com\/en-us\/security\/blog\/2026\/05\/06\/clickfix-campaign-uses-fake-macos-utilities-lures-deliver-infostealers\/"],"industries":[],"extract_source":[],"more_indicators":false},{"id":"69fb57e600c03f5a6ac63de0","name":"Operation Silent Rotor: Rust-Based Malware Targets Eurasian Unmanned Aviation Sector Ahead of Moscow Summit","description":"A sophisticated spear phishing campaign targets professionals in the Eurasian unmanned aviation sector, timed to coincide with the XIII Eurasian International Forum 'Unmanned Aviation 2026' in Moscow. The attack delivers malicious archives containing Rust-based executables disguised as legitimate documents from the Russian Aeronautical Information Center. The malware displays aviation-themed decoy documents in Russian while collecting system information including hostnames, volume serial numbers, network adapter details, and environment variables. Collected data is encrypted via XOR and exfiltrated to a C2 server over HTTPS. The malware subsequently downloads and executes a second-stage payload using AES-256 decryption. The campaign demonstrates targeted social engineering with realistic aviation order documents, translation certificates, and product summaries to compromise victims in Russia, Tajikistan, Central Asia, Middle East and Europe.","author_name":"AlienVault","modified":"2026-06-05T15:04:42.314000","created":"2026-05-06T15:01:58.919000","revision":2,"tlp":"white","public":1,"adversary":"","indicators":[{"id":4346299530,"indicator":"2064ef387ac9e51ba72b32004d99e8a0b291dbab24ed8db30f437abf1b40cb49","type":"FileHash-SHA256","created":"2026-05-06T15:01:59","content":"","title":"","description":"","expiration":null,"is_active":1,"role":null},{"id":4346299531,"indicator":"57e26f6e3b311a1064c946b69159ee05abedf9228b2f95c65536429e7ac7fb24","type":"FileHash-SHA256","created":"2026-05-06T15:01:59","content":"","title":"","description":"","expiration":null,"is_active":1,"role":null},{"id":4346299532,"indicator":"89f8e42c825d09a0a50e99bbf7304d7037be33ea362a57d34f87fa7981f80126","type":"FileHash-SHA256","created":"2026-05-06T15:01:59","content":"","title":"","description":"","expiration":null,"is_active":1,"role":null},{"id":4346299533,"indicator":"a7bd8869293212e1671df90d2d41b96d4933eb9408b1111bd830e111a91bb202","type":"FileHash-SHA256","created":"2026-05-06T15:01:59","content":"","title":"","description":"","expiration":null,"is_active":1,"role":null},{"id":4346299534,"indicator":"fdef9e489f773319f55f92f712d1b7b5447d59a632b8f4173d1b161d3759ad92","type":"FileHash-SHA256","created":"2026-05-06T15:01:59","content":"","title":"","description":"","expiration":null,"is_active":1,"role":null},{"id":4346299538,"indicator":"http:\/\/kleymarket.ru","type":"URL","created":"2026-05-06T15:01:59","content":"","title":"","description":"","expiration":null,"is_active":1,"role":null},{"id":4346299539,"indicator":"kleymarket.ru","type":"domain","created":"2026-05-06T15:01:59","content":"","title":"","description":"","expiration":null,"is_active":1,"role":null},{"id":4346299540,"indicator":"cdn.kleymarket.ru","type":"hostname","created":"2026-05-06T15:01:59","content":"","title":"","description":"","expiration":null,"is_active":1,"role":null}],"tags":["c2 exfiltration","multi-stage payload","aviation sector","unmanned aerial systems","spear phishing","rust malware","operation silent rotor","moscow summit"],"targeted_countries":["Russian Federation","Tajikistan"],"malware_families":[],"attack_ids":["T1033","T1204.002","T1566.001","T1082","T1106","T1140","T1016","T1083","T1036.004","T1041","T1027","T1059.003","T1071.001","T1105","T1090.001"],"references":["https:\/\/www.seqrite.com\/blog\/operation-silent-rotor-rust-malware-unmanned-aviation-sector\/"],"industries":["Aerospace"],"extract_source":[],"more_indicators":false},{"id":"69fb17376737204f3abf5eaf","name":"Malware Bypasses Browser Application-Bound Encryption Protections","description":"A sophisticated 64-bit information-stealing malware named Remus has emerged as a direct evolution of the notorious Lumma Stealer. Following the doxxing of alleged Lumma core members between August and October 2025, developers created this advanced variant, with test builds appearing in September 2025 and live campaigns starting February 2026. Remus employs innovative techniques including injecting custom 51-byte shellcode into browser memory to extract protected master keys, bypassing Application-Bound Encryption in Chromium-based browsers. The malware utilizes EtherHiding through Ethereum smart contracts for command-and-control resolution, making infrastructure takedowns nearly impossible. It targets browser credentials, session cookies, and cryptocurrency wallets while implementing rigorous anti-analysis checks to evade security research environments.","author_name":"AlienVault","modified":"2026-06-05T10:27:59.075000","created":"2026-05-06T10:25:59.272000","revision":2,"tlp":"white","public":1,"adversary":"","indicators":[],"tags":["etherhiding","browser credential theft","ethereum blockchain c2","remus","tenzor","cryptocurrency wallet theft","application-bound encryption bypass","information stealer","lumma stealer"],"targeted_countries":[],"malware_families":["Remus","Lumma Stealer","Tenzor"],"attack_ids":["T1003","T1539","T1082","T1106","T1140","T1036","T1055","T1555.003","T1059","T1497","T1552.001","T1562.001","T1027","T1573","T1518.001","T1070.004","T1134","T1071.001","T1105"],"references":["https:\/\/cyberpress.org\/remus-bypasses-browser-encryption\/"],"industries":[],"extract_source":[],"more_indicators":false},{"id":"6a21844636a81843ce1af3cc","name":"Matryoshka #3\/3: Gamaredon's Gammasteel Infostealer","description":"This analysis examines Gamaredon's (UAC-0010, Armagedon) advanced espionage operations targeting Ukrainian government, military, and critical infrastructure. The FSB-operated group deploys GammaSteel, a sophisticated stealer operating almost entirely from memory using Windows DPAPI encryption and storing 71 distinct payload functions in the HKCU\\Printers registry key. The malware employs three concurrent data acquisition mechanisms: timed drive scans, USB monitoring for air-gapped systems, and real-time file surveillance. Exfiltration occurs via legitimate S3-compatible cloud storage (Tebi.io) with fallback to operator-controlled servers. The infection chain extensively uses VBScript for evasion, Dead Drop Resolvers on platforms like Telegram and Mastodon for C2 configuration, and includes bidirectional backdoor capabilities enabling arbitrary remote code execution. Infrastructure demonstrates high automation with servers rotated approximately every 24 hours.","author_name":"AlienVault","modified":"2026-06-05T08:46:33.421000","created":"2026-06-04T13:57:26.399000","revision":2,"tlp":"white","public":1,"adversary":"Gamaredon","indicators":[{"id":4393177743,"indicator":"https:\/\/justsstop.ru\/","type":"URL","created":"2026-06-04T13:57:27","content":"","title":"","description":"","expiration":null,"is_active":1,"role":null},{"id":4393177744,"indicator":"justsstop.ru","type":"domain","created":"2026-06-04T13:57:27","content":"","title":"","description":"","expiration":null,"is_active":1,"role":null},{"id":4393294907,"indicator":"165.22.170.129","type":"IPv4","created":"2026-06-04T14:23:14","content":"","title":"","description":"","expiration":"2026-07-04T00:00:00","is_active":1,"role":null},{"id":4393294907,"indicator":"165.22.170.129","type":"IPv4","created":"2026-06-04T14:23:23","content":"","title":"","description":"","expiration":"2026-07-04T00:00:00","is_active":1,"role":null}],"tags":["vbscript","gammaworm","cyberespionage","ukraine","fsb","usb-propagation","gammasteel","gammaphish","gammawipe","gamaredon","dead-drop-resolver","infostealer","gammaload","dpapi"],"targeted_countries":["Ukraine"],"malware_families":["GammaSteel","GammaLoad","GammaPhish","GammaWorm","GammaWipe"],"attack_ids":["T1025","T1074.001","T1119","T1005","T1140","T1055","T1112","T1102","T1041","T1059.001","T1547.001","T1056.002","T1571","T1027","T1567.002","T1059.005","T1008","T1564.004"],"references":["https:\/\/blog.sekoia.io\/fsbs-matryoshka-3-3-gamaredons-gifts-that-keeps-unpacking-gammasteel\/"],"industries":["Government","Defense"],"extract_source":[],"more_indicators":false},{"id":"6a2201a2fe176ac0486f58e5","name":"Latest goon squad to use fake helpdesk calls to steal creds","description":"A new extortion group called Pink, tracked as cluster CL-CRI-1147, employs voice phishing and fake IT helpdesk impersonation to compromise organizations. The gang steals employee credentials, bypasses multi-factor authentication, and exfiltrates data from cloud storage platforms like SharePoint and OneDrive. Pink threatens to leak stolen information unless ransom demands are met, setting 72-hour deadlines. The group's data-leak site launched on May 31, 2026. This approach mirrors tactics popularized by Lapsus$, Scattered Spider, and ShinyHunters. Incident responders link Pink to The Com, a loosely connected network of English-speaking hackers and extortionists. Attackers use compromised victim accounts and internal Teams messages for extortion communications, reusing domains across multiple targets.","author_name":"AlienVault","modified":"2026-06-05T06:20:30.873000","created":"2026-06-04T22:52:18.927000","revision":2,"tlp":"white","public":1,"adversary":"Pink","indicators":[{"id":2225225534,"indicator":"185.178.208.153","type":"IPv4","created":"2026-06-04T22:52:19","content":"","title":"","description":"","expiration":"2026-07-04T22:00:00","is_active":1,"role":null},{"id":4327345632,"indicator":"deploypasskey.com","type":"domain","created":"2026-06-04T22:52:19","content":"","title":"","description":"","expiration":null,"is_active":1,"role":null},{"id":4394500427,"indicator":"96.232.20.66","type":"IPv4","created":"2026-06-04T22:52:19","content":"","title":"","description":"","expiration":"2026-07-04T22:00:00","is_active":1,"role":null},{"id":4394500428,"indicator":"passkeyadd.com","type":"domain","created":"2026-06-04T22:52:19","content":"","title":"","description":"","expiration":null,"is_active":1,"role":null},{"id":4394500429,"indicator":"passkeydeploy.com","type":"domain","created":"2026-06-04T22:52:19","content":"","title":"","description":"","expiration":null,"is_active":1,"role":null}],"tags":["mfa bypass","the com","credential phishing","social engineering","vishing","helpdesk impersonation","extortion","cloud data theft"],"targeted_countries":[],"malware_families":[],"attack_ids":[],"references":["https:\/\/www.theregister.com\/cyber-crime\/2026\/06\/04\/pink-is-the-latest-goon-squad-to-use-fake-helpdesk-calls-to-steal-creds\/5251434"],"industries":[],"extract_source":[],"more_indicators":false}],"count":8598,"prefetch_pulse_ids":false,"t":0,"t2":0.05275082588195801,"t3":0.09268355369567871,"previous":null,"next":"https:\/\/otx.alienvault.com\/api\/v1\/pulses\/subscribed?limit=5&page=2"}