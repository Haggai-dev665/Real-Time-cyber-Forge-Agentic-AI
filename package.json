{
  "name": "cyber-forge-ai-platform",
  "version": "1.0.0",
  "description": "Real-Time Cyber Forge Agentic AI Platform - Complete cybersecurity solution",
  "private": true,
  "workspaces": [
    "desktop-app",
    "mobile-app", 
    "landing-page",
    "backend"
  ],
  "scripts": {
    "install:all": "npm install && npm run install:desktop && npm run install:mobile && npm run install:landing && npm run install:backend && npm run install:ml",
    "install:desktop": "cd desktop-app && npm install",
    "install:mobile": "cd mobile-app && npm install", 
    "install:landing": "cd landing-page && npm install",
    "install:backend": "cd backend && npm install",
    "install:ml": "cd ml-services && pip install -r requirements.txt",
    
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:ml\" \"npm run dev:landing\"",
    "dev:desktop": "cd desktop-app && npm run dev",
    "dev:mobile": "cd mobile-app && npm start",
    "dev:landing": "cd landing-page && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "dev:ml": "cd ml-services && python main.py",
    
    "build": "npm run build:desktop && npm run build:mobile && npm run build:landing && npm run build:backend",
    "build:desktop": "cd desktop-app && npm run build",
    "build:mobile": "cd mobile-app && npm run build:android && npm run build:ios",
    "build:landing": "cd landing-page && npm run build",
    "build:backend": "cd backend && npm run build",
    
    "start": "concurrently \"npm run start:backend\" \"npm run start:ml\" \"npm run start:landing\"",
    "start:desktop": "cd desktop-app && npm start",
    "start:mobile": "cd mobile-app && npm start",
    "start:landing": "cd landing-page && npm start",
    "start:backend": "cd backend && npm start", 
    "start:ml": "cd ml-services && python main.py",
    
    "test": "npm run test:backend && npm run test:ml",
    "test:backend": "cd backend && npm test",
    "test:ml": "cd ml-services && pytest",
    
    "lint": "npm run lint:backend && npm run lint:landing",
    "lint:backend": "cd backend && npm run lint",
    "lint:landing": "cd landing-page && npm run lint",
    
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    
    "clean": "npm run clean:deps && npm run clean:builds",
    "clean:deps": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +",
    "clean:builds": "find . -name 'build' -type d -prune -exec rm -rf '{}' + && find . -name 'dist' -type d -prune -exec rm -rf '{}' +"
  },
  "keywords": [
    "cybersecurity",
    "ai",
    "machine-learning", 
    "electron",
    "react-native",
    "next.js",
    "threat-detection",
    "security-analysis",
    "real-time-monitoring"
  ],
  "author": "Haggai-dev665",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.0",
    "lerna": "^7.1.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0",
    "python": ">=3.9.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Haggai-dev665/Real-Time-cyber-Forge-Agentic-AI.git"
  },
  "homepage": "https://github.com/Haggai-dev665/Real-Time-cyber-Forge-Agentic-AI#readme",
  "bugs": {
    "url": "https://github.com/Haggai-dev665/Real-Time-cyber-Forge-Agentic-AI/issues"
  }
}