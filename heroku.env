# Heroku Environment Variables for CyberForge
# Set these in your Heroku dashboard or using Heroku CLI:
# heroku config:set VARIABLE_NAME=value --app cyberforge-ddd97655464f

NODE_ENV=production
PORT=8080

# JWT Configuration
JWT_SECRET=your-super-secure-jwt-secret-key-generated-with-openssl-rand-base64-64
JWT_EXPIRES_IN=24h

# CORS Configuration
ALLOWED_ORIGINS=https://cyberforge-ddd97655464f.herokuapp.com

# Database Configuration (use add-ons or external services)
# DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/cyberforge
# REDIS_URL=redis://username:password@hostname:port

# External API Keys
# GEMINI_API_KEY=your-gemini-api-key
# OTX_API_KEY=your-otx-api-key
# VIRUSTOTAL_API_KEY=your-virustotal-api-key

# HuggingFace ML Service (already configured)
HUGGINGFACE_ML_URL=https://che237-cyberforge-models.hf.space

# Security Settings
BCRYPT_SALT_ROUNDS=12
SESSION_TIMEOUT=86400000

# Application Settings
APP_NAME=CyberForge
APP_VERSION=2.0.0
APP_DOMAIN=cyberforge-ddd97655464f.herokuapp.com