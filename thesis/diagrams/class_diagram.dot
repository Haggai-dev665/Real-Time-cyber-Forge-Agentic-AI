digraph cyberforge_class {
  graph [rankdir=TB, splines=ortho, bgcolor="white", nodesep=0.55,
         ranksep=0.9, pad=0.5, fontname="Helvetica-Bold", fontsize=22,
         labelloc=t, label="CyberForge — Class Diagram (Agent-Orchestrator Subsystem)\n\n"];
  node [shape=plaintext, fontname="Helvetica"];
  edge [fontname="Helvetica", fontsize=10, penwidth=1.6, color="#5A6B82"];
  Orchestrator [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="5" COLOR="#5A6B82"><TR><TD BGCOLOR="#B9770E" ALIGN="CENTER"><FONT POINT-SIZE="13.5" COLOR="white"><B>AgentOrchestrator</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#16233D">- agents: Map&lt;string,BaseAgent&gt;</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#16233D">- memory: MemoryService</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#16233D">- reporter: ReporterAgent</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#16233D">- recentReports: Report[]</FONT></TD></TR></TABLE></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">+ analyze(url,sessionId,userId): Report</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">+ stats(): OrchestratorStats</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">+ recent(limit): Report[]</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">- dispatchStage1/2/3(ctx): Promise[]</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">- aggregate(ctx): Report</FONT></TD></TR></TABLE></TD></TR></TABLE>>];
  Base [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="5" COLOR="#5A6B82"><TR><TD BGCOLOR="#0A6B7B" ALIGN="CENTER"><FONT POINT-SIZE="9" COLOR="#EAF6F8"><I>«abstract»</I></FONT><BR/><FONT POINT-SIZE="13.5" COLOR="white"><I>BaseAgent</I></FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#16233D">+ name: string</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#16233D">+ role: string</FONT></TD></TR></TABLE></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">+ execute(ctx): AgentResult</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f"># _timed(fn): AgentResult</FONT></TD></TR></TABLE></TD></TR></TABLE>>];
  Ctx [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="5" COLOR="#5A6B82"><TR><TD BGCOLOR="#34507A" ALIGN="CENTER"><FONT POINT-SIZE="13.5" COLOR="white"><B>ScanContext</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#16233D">+ url, host: string</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#16233D">+ sessionId, userId: string</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#16233D">+ startedAt: number</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#16233D">+ scrape: ScrapeResult</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#16233D">+ agentResults: Map</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#16233D">+ iocs: IOC[]</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#16233D">+ mitre: MITRETechnique[]</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#16233D">+ findings: string[]</FONT></TD></TR></TABLE></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD> </TD></TR></TABLE></TD></TR></TABLE>>];
  Mem [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="5" COLOR="#5A6B82"><TR><TD BGCOLOR="#34507A" ALIGN="CENTER"><FONT POINT-SIZE="13.5" COLOR="white"><B>MemoryService</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#16233D">- domainHistory: Map</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#16233D">- sessionMemory: Map</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#16233D">- redis: RedisClient</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#16233D">- vectorDB: VectorClient</FONT></TD></TR></TABLE></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">+ getDomain(host): DomainMemory</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">+ recordVisit(host,verdict,score)</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">+ getSession(sid): SessionMemory</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">+ appendLLMContext(sid,msg)</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">+ stats(): MemoryStats</FONT></TD></TR></TABLE></TD></TR></TABLE>>];
  LLM [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="5" COLOR="#5A6B82"><TR><TD BGCOLOR="#6C3FBF" ALIGN="CENTER"><FONT POINT-SIZE="13.5" COLOR="white"><B>LLMFallbackChain</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#16233D">- providers: LLMProvider[]</FONT></TD></TR></TABLE></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">+ complete(prompt): LLMResponse</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">- tryGemini(prompt)</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">- tryMistral(prompt)</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">- heuristic(ctx)</FONT></TD></TR></TABLE></TD></TR></TABLE>>];
  App [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="5" COLOR="#5A6B82"><TR><TD BGCOLOR="#A03A30" ALIGN="CENTER"><FONT POINT-SIZE="13.5" COLOR="white"><B>AppwriteService</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD> </TD></TR></TABLE></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">+ createAlert(record)</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">+ listAlerts(userId,limit)</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">+ createAgentTask(task)</FONT></TD></TR></TABLE></TD></TR></TABLE>>];
  URLc [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="5" COLOR="#5A6B82"><TR><TD BGCOLOR="#0E8FA3" ALIGN="CENTER"><FONT POINT-SIZE="13.5" COLOR="white"><B>URLClassifierAgent</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#16233D">- mlServiceUrl: string</FONT></TD></TR></TABLE></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">+ execute(ctx)</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">- callBert(url)</FONT></TD></TR></TABLE></TD></TR></TABLE>>];
  DGAc [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="5" COLOR="#5A6B82"><TR><TD BGCOLOR="#0E8FA3" ALIGN="CENTER"><FONT POINT-SIZE="13.5" COLOR="white"><B>DGADetectorAgent</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD> </TD></TR></TABLE></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">+ execute(ctx)</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">- callDga(domain)</FONT></TD></TR></TABLE></TD></TR></TABLE>>];
  Scr [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="5" COLOR="#5A6B82"><TR><TD BGCOLOR="#0E8FA3" ALIGN="CENTER"><FONT POINT-SIZE="13.5" COLOR="white"><B>WebScraperAgent</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#16233D">- scraperUrl, apiKey</FONT></TD></TR></TABLE></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">+ execute(ctx)</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">- scrape(url)</FONT></TD></TR></TABLE></TD></TR></TABLE>>];
  MemA [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="5" COLOR="#5A6B82"><TR><TD BGCOLOR="#0E8FA3" ALIGN="CENTER"><FONT POINT-SIZE="13.5" COLOR="white"><B>MemoryAgent</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#16233D">- memory: MemoryService</FONT></TD></TR></TABLE></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">+ execute(ctx)</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">- readHistory(host)</FONT></TD></TR></TABLE></TD></TR></TABLE>>];
  IOC [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="5" COLOR="#5A6B82"><TR><TD BGCOLOR="#0E8FA3" ALIGN="CENTER"><FONT POINT-SIZE="13.5" COLOR="white"><B>IOCExtractorAgent</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#16233D">- patterns: Map</FONT></TD></TR></TABLE></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">+ execute(ctx)</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">- extract(text)</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">- dedupe(iocs)</FONT></TD></TR></TABLE></TD></TR></TABLE>>];
  Beh [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="5" COLOR="#5A6B82"><TR><TD BGCOLOR="#0E8FA3" ALIGN="CENTER"><FONT POINT-SIZE="13.5" COLOR="white"><B>BehaviouralAgent</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD> </TD></TR></TABLE></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">+ execute(ctx)</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">- inspectNet(reqs)</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">- inspectJs(logs)</FONT></TD></TR></TABLE></TD></TR></TABLE>>];
  MIT [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="5" COLOR="#5A6B82"><TR><TD BGCOLOR="#0E8FA3" ALIGN="CENTER"><FONT POINT-SIZE="13.5" COLOR="white"><B>MITREMapperAgent</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#16233D">- signals: Signal[]</FONT></TD></TR></TABLE></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">+ execute(ctx)</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">- match(text)</FONT></TD></TR></TABLE></TD></TR></TABLE>>];
  TI [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="5" COLOR="#5A6B82"><TR><TD BGCOLOR="#0E8FA3" ALIGN="CENTER"><FONT POINT-SIZE="13.5" COLOR="white"><B>ThreatIntelAgent</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#16233D">- otxClient: OTXClient</FONT></TD></TR></TABLE></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">+ execute(ctx)</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">- enrich(ioc)</FONT></TD></TR></TABLE></TD></TR></TABLE>>];
  Rep [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="5" COLOR="#5A6B82"><TR><TD BGCOLOR="#1E8449" ALIGN="CENTER"><FONT POINT-SIZE="13.5" COLOR="white"><B>ReporterAgent</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#16233D">- llmChain: LLMFallbackChain</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#16233D">- appwrite: AppwriteService</FONT></TD></TR></TABLE></TD></TR><TR><TD ALIGN="LEFT"><TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">+ execute(ctx): Report</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">- blendedScore(ctx)</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">- escalate(v,ctx)</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT FACE="Menlo" POINT-SIZE="10" COLOR="#1d3b2f">- narrative(ctx)</FONT></TD></TR></TABLE></TD></TR></TABLE>>];
  {rank=same; URLc; DGAc; Scr; MemA; IOC; Beh; MIT; TI; Rep;}
  {rank=same; Mem; Orchestrator; Ctx;}
  {rank=same; LLM; App;}
  Base -> URLc [dir=back, arrowtail=empty, arrowsize=1.3, color="#5A6B82", penwidth=1.6];
  Base -> DGAc [dir=back, arrowtail=empty, arrowsize=1.3, color="#5A6B82", penwidth=1.6];
  Base -> Scr [dir=back, arrowtail=empty, arrowsize=1.3, color="#5A6B82", penwidth=1.6];
  Base -> MemA [dir=back, arrowtail=empty, arrowsize=1.3, color="#5A6B82", penwidth=1.6];
  Base -> IOC [dir=back, arrowtail=empty, arrowsize=1.3, color="#5A6B82", penwidth=1.6];
  Base -> Beh [dir=back, arrowtail=empty, arrowsize=1.3, color="#5A6B82", penwidth=1.6];
  Base -> MIT [dir=back, arrowtail=empty, arrowsize=1.3, color="#5A6B82", penwidth=1.6];
  Base -> TI [dir=back, arrowtail=empty, arrowsize=1.3, color="#5A6B82", penwidth=1.6];
  Base -> Rep [dir=back, arrowtail=empty, arrowsize=1.3, color="#5A6B82", penwidth=1.6];
  Orchestrator -> Base [dir=back, arrowtail=odiamond, arrowsize=1.4, label="dispatches\n1..*", penwidth=1.7, color="#5A6B82"];
  Orchestrator -> Rep [dir=back, arrowtail=diamond, arrowsize=1.4, label="finalises", color="#B9770E", penwidth=1.7, fontcolor="#B9770E", constraint=false];
  Orchestrator -> Mem [style=dashed, arrowhead=vee, arrowsize=0.9, penwidth=1.5, label="«uses»", color="#34507A", fontcolor="#34507A"];
  Orchestrator -> Ctx [style=dashed, arrowhead=vee, arrowsize=0.9, penwidth=1.5, label="«creates»", color="#34507A", fontcolor="#34507A"];
  Base -> Ctx [style=dashed, arrowhead=vee, arrowsize=0.9, penwidth=1.5, label="reads / writes", color="#5A6B82", constraint=false];
  MemA -> Mem [style=dashed, arrowhead=vee, arrowsize=0.9, penwidth=1.5, label="reads", color="#34507A", fontcolor="#34507A", constraint=false];
  Rep -> LLM [style=dashed, arrowhead=vee, arrowsize=0.9, penwidth=1.5, label="«uses»", color="#6C3FBF", fontcolor="#6C3FBF"];
  Rep -> App [style=dashed, arrowhead=vee, arrowsize=0.9, penwidth=1.5, label="persists via", color="#A03A30", fontcolor="#A03A30"];
  Rep -> Mem [style=dashed, arrowhead=vee, arrowsize=0.9, penwidth=1.5, label="writes back", color="#1F9D57", fontcolor="#1F9D57", constraint=false];
}