# =======================================================
# CYBER FORGE AI - DESKTOP APP ENVIRONMENT CONFIGURATION
# =======================================================
# Copy this file to .env and fill in your actual values
# Never commit the .env file to version control!

# =======================================================
# BACKEND CONNECTION
# =======================================================
# Backend API URL
BACKEND_URL=http://localhost:8000

# ML Services URL
ML_SERVICE_URL=http://localhost:8001

# WebSocket URL
WS_URL=ws://localhost:8000/ws

# =======================================================
# GOOGLE OAUTH CONFIGURATION
# =======================================================
# Get these from Google Cloud Console:
# https://console.cloud.google.com/apis/credentials

# Google OAuth Client ID
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Google OAuth Client Secret
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth Redirect URI (must match Google Console config)
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# =======================================================
# FIREBASE CONFIGURATION
# =======================================================
# Get these from Firebase Console:
# https://console.firebase.google.com/project/YOUR_PROJECT/settings/general

# Firebase API Key
FIREBASE_API_KEY=your-firebase-api-key

# Firebase Auth Domain
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com

# Firebase Project ID
FIREBASE_PROJECT_ID=your-project-id

# Firebase Storage Bucket
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Firebase Messaging Sender ID
FIREBASE_MESSAGING_SENDER_ID=123456789

# Firebase App ID
FIREBASE_APP_ID=1:123456789:web:abc123

# =======================================================
# APPLICATION SETTINGS
# =======================================================
# Development mode (shows extra debugging info)
DEV_MODE=true

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Enable DevTools in production (not recommended)
ENABLE_DEVTOOLS=false

# Auto-update settings
AUTO_UPDATE=true
UPDATE_CHECK_INTERVAL=86400000

# =======================================================
# SECURITY SETTINGS
# =======================================================
# Session timeout (in milliseconds)
SESSION_TIMEOUT=86400000

# Remember me duration (in days)
REMEMBER_ME_DURATION=30

# Enable hardware acceleration
HARDWARE_ACCELERATION=true

# =======================================================
# UI SETTINGS
# =======================================================
# Default theme (light, dark)
DEFAULT_THEME=dark

# Default window size
WINDOW_WIDTH=1400
WINDOW_HEIGHT=900

# Minimum window size
MIN_WIDTH=1024
MIN_HEIGHT=768
